# Copy this file to .env and fill in the values for local development.
# .env is gitignored and must never be committed.

# PostgreSQL connection
DATABASE_URL=ecto://postgres:postgres@localhost/tesmoin_dev

# Phoenix secret key base — generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here

# Public hostname (no scheme, no port)
HOSTNAME=localhost

# SMTP — required for magic-link login to work
SMTP_HOST=smtp.example.com
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@example.com  # optional, defaults to SMTP_USER
# SMTP_PORT=587                  # optional, default 587
# SMTP_TLS=if_available          # optional: always | never | if_available
# SMTP_AUTH=if_available         # optional: always | never | if_available

# Reverse proxy IPs trusted to set X-Forwarded-For (production only).
# Comma-separated. Example: TRUSTED_PROXIES=127.0.0.1,10.0.0.1
#TRUSTED_PROXIES=
