# Copy this file to .env and fill in the values for local development.
# .env is gitignored and must never be committed.

# PostgreSQL connection
DATABASE_URL=ecto://postgres:postgres@localhost/tesmoin_dev

# Phoenix secret key base (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=your_secret_key_base_here

# Admin credentials (used on first boot to seed the admin user)
TESMOIN_ADMIN_EMAIL=admin@example.com
TESMOIN_ADMIN_PASSWORD=changeme123!

# Application port
PHX_PORT=4000
PHX_HOST=localhost
