<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found · Tesmoin</title>
     <link rel="icon" type="image/x-icon" href={~p"/favicon.ico?v=2"} />
    <link rel="shortcut icon" type="image/x-icon" href={~p"/favicon.ico?v=2"} />
    <link rel="stylesheet" href={~p"/assets/css/app.css"} />
  </head>
  
  <body class="min-h-screen bg-secondary-soft text-slate-900 antialiased">
    <main class="relative min-h-screen overflow-hidden">
      <div class="absolute inset-0 -z-10 backoffice-mesh"></div>
      
      <section class="mx-auto flex min-h-screen max-w-4xl items-center px-4 py-12 sm:px-6 lg:px-8">
        <div class="backoffice-card w-full p-8 text-center sm:p-12">
          <div class="mb-6 flex flex-col items-center gap-3">
            <img src={~p"/images/tesmoin-logo.png"} alt="Tesmoin" class="h-12 w-auto sm:h-14" />
            <h1 class="auth-brand-wordmark">Tesmoin</h1>
          </div>
          
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary-700">
            Error 404
          </p>
          
          <h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">Page not found</h2>
          
          <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-neutral-ink sm:text-base">
            Sorry, that page couldn't be found.
          </p>
          
          <div class="mt-7">
            <a href={~p"/"} class="backoffice-button-primary">Go back home</a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
